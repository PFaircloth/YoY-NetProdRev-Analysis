# Python bytecode cache
__pycache__/
*.py[cod]

# Generated reports (built by `python3 run.py`)
output/

# Data extracts & backups — volatile/large, not version-controlled.
# Covers the canonical X. DAX_ProcedureMix.xlsx, the W re-pull, and *.pre_*.bak
# promotion backups. (A. and B. were tracked before this rule and stay tracked.)
data/*.xlsx
data/*.bak
